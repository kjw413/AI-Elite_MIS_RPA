# MIS RPA 환경설정 — 복사해서 `.env` 로 저장하세요.
#
# 이 프로젝트는 MIS 화면에서 데이터를 수집·재가공해 아래 공유 폴더에 엑셀로 저장합니다.
# 웹앱(AI-Elite_Energy-Dashboard-Web)은 서버 기동 시 같은 폴더의 엑셀을 읽어 DB에 적재합니다.
# 따라서 SAMPLED_DB_DIR 은 웹앱의 .env 와 반드시 동일해야 합니다.

# 수집 원본/산출물 공유 폴더 (웹앱과 동일)
SAMPLED_DB_DIR=E:\Sampled DB

# (선택) 개별 파일 경로 오버라이드 — 미설정 시 SAMPLED_DB_DIR 기준 기본 파일명 사용
# RawDB_생산실적.xlsx
# PRODUCTION_RAW_XLSX=
# DB_생산실적.xlsx (재가공 산출물 = 웹이 읽는 통합 파일)
# PRODUCTION_DW_XLSX=
# RawDB_에너지.xlsx
# ENERGY_SOURCE_XLSX=
# RawDB_재공품.xlsx
# WIP_ITEM_MASTER_XLSX=
